From 11641727e21e50ef83bd86598305c9bfbac583d5 Mon Sep 17 00:00:00 2001
From: Chris Burr <christopher.burr@cern.ch>
Date: Fri, 27 Feb 2026 11:02:33 +0100
Subject: [PATCH] feat: use ROOT's own libc.modulemap on macOS instead of SDK's
 Darwin module

Replace Apple SDK's Darwin module with ROOT's own libc.modulemap on
macOS, matching the approach already used on Linux. This decouples
ROOT's PCM system from Apple's proprietary modulemap hierarchy,
reducing fragility across SDK versions.

- Add POSIX headers to libc.modulemap (stdint, unistd, fcntl, dlfcn,
  dirent, pwd, grp, sys/types, sys/stat, stdarg)
- Install libc.modulemap on macOS (remove NOT APPLE guard)
- Stop loading SDK's module.modulemap; add libc.modulemap overlay
- Load libc module instead of Darwin on all non-Windows platforms
- Clean up libc.pcm instead of Darwin.pcm on macOS
---
 core/clingutils/CMakeLists.txt                |  4 +-
 core/dictgen/src/rootcling_impl.cxx           |  4 --
 core/metacling/src/TCling.cxx                 |  4 --
 .../cling/include/cling/libc.modulemap        | 44 +++++++++++++++++++
 .../cling/lib/Interpreter/CIFactory.cpp       |  9 ++--
 5 files changed, 50 insertions(+), 15 deletions(-)

diff --git a/core/clingutils/CMakeLists.txt b/core/clingutils/CMakeLists.txt
index b0ca97cf06..972ab10f0f 100644
--- a/core/clingutils/CMakeLists.txt
+++ b/core/clingutils/CMakeLists.txt
@@ -153,10 +153,10 @@ if (runtime_cxxmodules)
       set(custom_modulemaps ${custom_modulemaps} std.modulemap)
     endif()
   endif()
-  # Handle libc. Apple's libc is modularized.
+  # Handle libc.
   if (MSVC)
     set(custom_modulemaps ${custom_modulemaps} libc_msvc.modulemap)
-  elseif (NOT APPLE)
+  else()
     set(custom_modulemaps ${custom_modulemaps} libc.modulemap)
   endif()
 endif(runtime_cxxmodules)
diff --git a/core/dictgen/src/rootcling_impl.cxx b/core/dictgen/src/rootcling_impl.cxx
index 99942be55d..8061a54f2a 100644
--- a/core/dictgen/src/rootcling_impl.cxx
+++ b/core/dictgen/src/rootcling_impl.cxx
@@ -4331,11 +4331,7 @@ int RootClingMain(int argc,
          remove((moduleCachePath + llvm::sys::path::get_separator() + "services.pcm").str().c_str());
 #endif
 
-#ifdef R__MACOSX
-         remove((moduleCachePath + llvm::sys::path::get_separator() + "Darwin.pcm").str().c_str());
-#else
          remove((moduleCachePath + llvm::sys::path::get_separator() + "libc.pcm").str().c_str());
-#endif
          remove((moduleCachePath + llvm::sys::path::get_separator() + "std.pcm").str().c_str());
          remove((moduleCachePath + llvm::sys::path::get_separator() + "boost.pcm").str().c_str());
          remove((moduleCachePath + llvm::sys::path::get_separator() + "tinyxml2.pcm").str().c_str());
diff --git a/core/metacling/src/TCling.cxx b/core/metacling/src/TCling.cxx
index ab35d1b5a9..cfa581781a 100644
--- a/core/metacling/src/TCling.cxx
+++ b/core/metacling/src/TCling.cxx
@@ -1231,11 +1231,7 @@ static void RegisterCxxModules(cling::Interpreter &clingInterp)
    LoadModule("services", clingInterp);
 #endif
 
-#ifdef R__MACOSX
-   LoadModule("Darwin", clingInterp);
-#else
    LoadModule("libc", clingInterp);
-#endif
    LoadModule("std", clingInterp);
 
    LoadModule("_Builtin_intrinsics", clingInterp);
diff --git a/interpreter/cling/include/cling/libc.modulemap b/interpreter/cling/include/cling/libc.modulemap
index 9137a4283a..1207b90233 100644
--- a/interpreter/cling/include/cling/libc.modulemap
+++ b/interpreter/cling/include/cling/libc.modulemap
@@ -10,6 +10,10 @@ module "libc" [system] [extern_c] [no_undeclared_includes] {
     export *
     header "string.h"
   }
+  module "strings.h" {
+    export *
+    header "strings.h"
+  }
   module "ctype.h" {
     export *
     header "ctype.h"
@@ -62,4 +66,44 @@ module "libc" [system] [extern_c] [no_undeclared_includes] {
     export *
     header "wchar.h"
   }
+  module "stdint.h" {
+    export *
+    header "stdint.h"
+  }
+  module "stdarg.h" {
+    export *
+    textual header "stdarg.h"
+  }
+  module "unistd.h" {
+    export *
+    header "unistd.h"
+  }
+  module "fcntl.h" {
+    export *
+    header "fcntl.h"
+  }
+  module "dlfcn.h" {
+    export *
+    header "dlfcn.h"
+  }
+  module "dirent.h" {
+    export *
+    header "dirent.h"
+  }
+  module "pwd.h" {
+    export *
+    header "pwd.h"
+  }
+  module "grp.h" {
+    export *
+    header "grp.h"
+  }
+  module "sys_types.h" {
+    export *
+    header "sys/types.h"
+  }
+  module "sys_stat.h" {
+    export *
+    header "sys/stat.h"
+  }
 }
diff --git a/interpreter/cling/lib/Interpreter/CIFactory.cpp b/interpreter/cling/lib/Interpreter/CIFactory.cpp
index 9918c7b0aa..8ff3a9ae95 100644
--- a/interpreter/cling/lib/Interpreter/CIFactory.cpp
+++ b/interpreter/cling/lib/Interpreter/CIFactory.cpp
