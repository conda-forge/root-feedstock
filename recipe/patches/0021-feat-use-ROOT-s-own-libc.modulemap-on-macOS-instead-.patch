-        ModuleMapFiles.push_back(libcModuleMap.str().str());
-      }
     }
 
     std::string MOverlay;
@@ -728,6 +723,10 @@ namespace {
                             /*RegisterModuleMap=*/ true,
                             /*AllowModulemapOverride=*/ false);
 #elif __APPLE__
